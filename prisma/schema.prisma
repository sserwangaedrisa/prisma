generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String        @id @default(uuid())
  email              String        @unique
  name               String
  createdAt          DateTime      @default(now())
  isActive           Boolean       @default(true)
  password           String
  phone              String?
  role               Role
  job                Job       @default(USER)
  wageRating         Float?        @default(0.0)
  updatedAt          DateTime      @updatedAt
  imageUrl           String?       @default("")
  status             UserStatus     @default(INACTIVE)
  verificationCode   String?      
  verificationExpiry DateTime?
  deactivatedAt      DateTime?
  deactivationReason String?
  reactivatedAt      DateTime?
  sites              String?
  activityLogs       ActivityLog[]
  payments           Payment[]
  foremanSites       Site[]        @relation("ForemanSites")
  ownedSites         Site[]        @relation("OwnerSites")
  assignedSites      SiteWorker[]
  workerRecords      WorkEntry[]


   @@index([status])
  @@index([role])
  @@index([email])
  @@index([isActive])
}

model Site {
  id          String       @id @default(uuid())
  name        String
  location    String
  description String?
  ownerId     String?
  foremanId   String?
  dutyHours   Float?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  monthCloses MonthClose[]
  payments    Payment[]
  foreman     User?        @relation("ForemanSites", fields: [foremanId], references: [id])
  owner       User?        @relation("OwnerSites", fields: [ownerId], references: [id])
  workers     SiteWorker[]
  workEntries WorkEntry[]
  settings   Settings[]

   @@index([foremanId])
}

model SiteWorker {
  id         String   @id @default(uuid())
  siteId     String
  workerId   String
  assignedAt DateTime @default(now())
  site       Site     @relation(fields: [siteId], references: [id])
  worker     User     @relation(fields: [workerId], references: [id])

    @@index([siteId])
  @@index([workerId])

}

model WorkEntry {
  id        String   @id @default(uuid())
  workerId  String
  siteId    String
  date      DateTime @default(now())
  hours     Float
  overtime  Float    @default(0)
  notes     String?
  status    WorkEntryStatus @default(NOT_PAID)
  paymentId String? 
  createdAt DateTime @default(now())
  site      Site     @relation(fields: [siteId], references: [id])
  worker    User     @relation(fields: [workerId], references: [id])
  payment   Payment? @relation(fields: [paymentId], references: [id], onDelete: Cascade)


  @@index([workerId, siteId, date, status])
  @@index([siteId, date, status])
  @@index([workerId, status])
  @@index([date])
  @@index([paymentId])
}


model MonthClose {
  id        String      @id @default(uuid())
  siteId    String
  month     Int
  year      Int
  status    MonthStatus @default(OPEN)
  lockedAt  DateTime?
  createdAt DateTime    @default(now())
  site      Site        @relation(fields: [siteId], references: [id])

  @@index([siteId, status])
  @@index([year, month])

}


model Payment {
  id          String        @id @default(uuid())
  workerId    String
  siteId      String
  month       Int
  year        Int
  totalHours  Float
  overtime    Float
  baseAmount  Float
  batchId     String?       @map("batch_id")
  overtimePay Float
  totalAmount Float
  status      PaymentStatus @default(PENDING)
  approvedAt  DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  site        Site          @relation(fields: [siteId], references: [id])
  worker      User          @relation(fields: [workerId], references: [id])
  workEntries WorkEntry[] 

  @@index([workerId])
  @@index([siteId])
  @@index([batchId])
  @@index([status])
  @@index([month, year])
}

model Settings {
  id             String   @id @default(uuid())
  overtimeRate   Float    @default(0)
  maxDailyHours  Float    @default(10)
  baseHourlyRate Float    @default(0)
  siteId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  site           Site     @relation(fields: [siteId], references: [id])

  @@index([siteId, createdAt])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  createdAt DateTime @default(now())
  user      User?     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([action])

}

enum Role {
  OWNER
  FOREMAN
  WORKER
  LABORER
}

enum PaymentStatus {
  PENDING
  APPROVED
  PAID
}

enum MonthStatus {
  OPEN
  LOCKED
}


enum WorkEntryStatus {
  NOT_PAID      // not yet selected for payment
  PENDING       // foreman selected it
  PAID          // owner paid it
  APPROVED      // OWNER HAS approved it for payment
  REVIEW        // Owner has set it back to forman for review
  REJECTED      // Owner has permanetly REJECTED the entry
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BLOCKED
  DELETED
}

enum Job {
  USER
  HELPER
  MASON
  STEEL_FIXER
  FOREMAN
  SITE_ADMIN
  PAINTER
  ELECTRICIAN
  ADMIN
}