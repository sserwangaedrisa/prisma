generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String        @id @default(uuid())
  email              String        @unique
  name               String
  createdAt          DateTime      @default(now())
  password           String
  phone              String?
  isActive           Boolean       @default(false)
  role               Role
  updatedAt          DateTime      @updatedAt
  verificationCode   String?
  verificationExpiry DateTime?
  sites              String?
  imageUrl           String?       @default("")
  wageRating         Float?        @default(0.0)
  deactivatedAt      DateTime?
  deactivationReason String?
  reactivatedAt      DateTime?
  status             UserStatus    @default(ACTIVE)
  job                Job?          @default(USER)
  activityLogs       ActivityLog[]
  foremanSites       Site[]        @relation("ForemanSites")
  ownedSites         Site[]        @relation("OwnerSites")
  payments           Payment[]
  workerRecords      WorkEntry[]

  @@index([status])
  @@index([role])
  @@index([email])
}

model Site {
  id          String     @id @default(uuid())
  name        String
  location    String
  description String?
  ownerId     String?
  foremanId   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  dutyHours   Float?
  foreman     User?      @relation("ForemanSites", fields: [foremanId], references: [id])
  owner       User?      @relation("OwnerSites", fields: [ownerId], references: [id])
  settings    Settings[] // Added this relation

  @@index([ownerId])
  @@index([foremanId])
}

model SiteWorker {
  id         String   @id @default(uuid())
  siteId     String
  workerId   String
  assignedAt DateTime @default(now())
  assignedBy String?

  @@index([siteId])
  @@index([workerId])
}

model WorkEntry {
  id        String          @id @default(uuid())
  workerId  String
  siteId    String
  date      DateTime        @default(now())
  hours     Float
  overtime  Float           @default(0)
  notes     String?
  createdAt DateTime        @default(now())
  paymentId String?
  status    WorkEntryStatus @default(NOT_PAID)
  createdBy String?
  payment   Payment?        @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  worker    User?           @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId, siteId, date, status])
  @@index([siteId, date, status])
  @@index([workerId, status])
  @@index([date])
  @@index([paymentId])
}

model MonthClose {
  id        String      @id @default(uuid())
  siteId    String
  month     Int
  year      Int
  status    MonthStatus @default(OPEN)
  lockedAt  DateTime?
  createdAt DateTime    @default(now())
  lockedBy  String?

  @@index([siteId, status])
  @@index([year, month])
}

model Payment {
  id          String        @id @default(uuid())
  workerId    String
  siteId      String
  month       Int
  year        Int
  totalHours  Float
  overtime    Float
  baseAmount  Float
  overtimePay Float
  totalAmount Float
  status      PaymentStatus @default(PENDING)
  approvedAt  DateTime?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  approvedBy  String?
  paidBy      String?
  workEntries WorkEntry[]
  worker      User?         @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@index([workerId])
  @@index([siteId])
  @@index([status])
  @@index([month, year])
}

model Settings {
  id             String   @id @default(uuid())
  overtimeRate   Float    @default(1.5)
  maxDailyHours  Float    @default(10)
  baseHourlyRate Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  siteId         String
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  createdAt DateTime @default(now())
  ipAddress String?
  metadata  Json?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@index([action])
}

enum Role {
  OWNER
  FOREMAN
  WORKER
  LABORER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BLOCKED
  DELETED
}

enum Job {
  USER
  HELPER
  MASON
  STEEL_FIXER
  FOREMAN
  SITE_ADMIN
  PAINTER
  ELECTRICIAN
  ADMIN
}

enum WorkEntryStatus {
  NOT_PAID
  PENDING
  PAID
}

enum PaymentStatus {
  PENDING
  APPROVED
  PAID
}

enum MonthStatus {
  OPEN
  LOCKED
}
